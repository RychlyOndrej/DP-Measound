<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window -->
    <SolidColorBrush x:Key="WindowBackground" Color="#FF1E1E1E"/>
    <SolidColorBrush x:Key="WindowForeground" Color="#FFFFFFFF"/>

    <!-- Controls -->
    <SolidColorBrush x:Key="ControlBackground" Color="#FF2D2D2D"/>
    <SolidColorBrush x:Key="ControlBorder" Color="#FF555555"/>
    <SolidColorBrush x:Key="TextForeground" Color="#FFEAEAEA"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="ComboBoxBackground" Color="#FF2A2A2A"/>
    <SolidColorBrush x:Key="ComboBoxSelected" Color="#FF3A3A3A"/>

    <!-- Disabled Buttons -->
    <SolidColorBrush x:Key="ButtonDisabledBackground" Color="#FF252525"/>
    <SolidColorBrush x:Key="ButtonDisabledBorder" Color="#FF3A3A3A"/>
    <SolidColorBrush x:Key="ButtonDisabledForeground" Color="#FF777777"/>

    <!-- Selection -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#FF4A90E2"/>

</ResourceDictionary>
