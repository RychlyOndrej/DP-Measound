<Window x:Class="MeaSound.MicCalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kalibrace urovni mikrofonu"
        Width="500" Height="680"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource TextForeground}"
        FontFamily="Segoe UI Variable, Segoe UI"
        Closing="Window_Closing">

    <StackPanel Margin="16">

        <TextBlock TextWrapping="Wrap" Margin="0,0,0,10" FontSize="12"
                   Foreground="{DynamicResource TextForeground}"
                   Text="Prehrajte 1 kHz sinusoidu a nastavte uroven tak, aby byly urovne Output a Reference (nebo Mikrofon) co nejblize. Rozdil by mel byt mensi nez 1 dB."/>

        <GroupBox Header="Vystup (reproduktor / zvukovka)" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Zarizeni:"
                           Foreground="{DynamicResource TextForeground}"
                           VerticalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtOutputDevice" Grid.Row="0" Grid.Column="1"
                           VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextForeground}"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Uroven signalu:"
                           Foreground="{DynamicResource TextForeground}"
                           VerticalAlignment="Center" Margin="0,4,0,0"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Center">
                    <RepeatButton x:Name="BtnLevelDown" Content="&#x25BC;" Width="26" Height="26"
                                  FontSize="11" Padding="0"
                                  Click="BtnLevelDown_Click"/>
                    <TextBox x:Name="TxtLevelDb" Text="0.0 dB"
                             Width="72" Height="26" Margin="4,0"
                             VerticalContentAlignment="Center"
                             HorizontalContentAlignment="Center"
                             FontWeight="SemiBold" Foreground="#FF2196F3"
                             KeyDown="TxtLevelDb_KeyDown"
                             LostFocus="TxtLevelDb_LostFocus"
                             PreviewMouseWheel="TxtLevelDb_MouseWheel"/>
                    <RepeatButton x:Name="BtnLevelUp" Content="&#x25B2;" Width="26" Height="26"
                                  FontSize="11" Padding="0"
                                  Click="BtnLevelUp_Click"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="RMS vystup:"
                           Foreground="{DynamicResource TextForeground}"
                           VerticalAlignment="Center" Margin="0,6,0,0"/>
                <TextBlock x:Name="TxtOutputLevel" Grid.Row="2" Grid.Column="1"
                           Text="&#x2013; dBFS" FontSize="18" FontWeight="Bold"
                           Foreground="#FF2196F3" VerticalAlignment="Center" Margin="0,6,0,0"/>

                <ProgressBar x:Name="PbOutput" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                             Minimum="-60" Maximum="0" Value="-60"
                             Height="14" Margin="0,4,0,0"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Vstup - Mikrofon" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Zarizeni:"
                           Foreground="{DynamicResource TextForeground}"
                           VerticalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtInputDevice" Grid.Row="0" Grid.Column="1"
                           VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextForeground}"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="RMS vstup:"
                           Foreground="{DynamicResource TextForeground}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtInputLevel" Grid.Row="1" Grid.Column="1"
                           Text="&#x2013; dBFS" FontSize="18" FontWeight="Bold"
                           Foreground="#FF4CAF50" VerticalAlignment="Center"/>

                <ProgressBar x:Name="PbInput" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                             Minimum="-60" Maximum="0" Value="-60"
                             Height="14" Margin="0,4,0,0"/>
            </Grid>
        </GroupBox>

        <GroupBox x:Name="GroupBoxReference" Header="Vstup - Reference (loopback)" Padding="8" Margin="0,0,0,8"
                  Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Kanal:"
                           Foreground="{DynamicResource TextForeground}"
                           VerticalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtReferenceDevice" Grid.Row="0" Grid.Column="1"
                           VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,4"
                           Foreground="{DynamicResource TextForeground}"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="RMS reference:"
                           Foreground="{DynamicResource TextForeground}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtReferenceLevel" Grid.Row="1" Grid.Column="1"
                           Text="&#x2013; dBFS" FontSize="18" FontWeight="Bold"
                           Foreground="#FFFF9800" VerticalAlignment="Center"/>

                <ProgressBar x:Name="PbReference" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                             Minimum="-60" Maximum="0" Value="-60"
                             Height="14" Margin="0,4,0,0"/>
            </Grid>
        </GroupBox>

        <GroupBox Padding="8" Margin="0,0,0,12">
            <GroupBox.Header>
                <TextBlock x:Name="TxtDeltaHeader"
                           Text="Vyrovnani (Output &#x2013; Mikrofon)"
                           Foreground="{DynamicResource TextForeground}"/>
            </GroupBox.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Rozdil:"
                           Foreground="{DynamicResource TextForeground}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtDelta" Grid.Row="0" Grid.Column="1"
                           Text="&#x2013; dB" FontSize="22" FontWeight="Bold"
                           Foreground="DarkOrange" VerticalAlignment="Center"/>

                <TextBlock x:Name="TxtHint" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="" TextWrapping="Wrap" Margin="0,6,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource TextForeground}"
                           Opacity="0.6"/>
            </Grid>
        </GroupBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="BtnStartStop" Content="&#x25BA;  Spustit 1 kHz"
                    Width="160" Padding="10,6" Margin="0,0,12,0"
                    Click="BtnStartStop_Click"/>
            <Button Content="Zavrit"
                    Width="100" Padding="10,6"
                    Click="BtnClose_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
